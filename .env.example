# 复制本文件为 .env 后修改（.env 不提交到 git）
# 服务端口
PORT=3000

# SQLite 数据库文件路径（相对或绝对都行；上云时改到持久化目录）
DB_PATH=./signin.db

# 登录 token 签名密钥（自己随便改一串长字符）
JWT_SECRET=change_this_to_a_long_random_secret_string

# 演示用「今天」日期（可选）。
# 不设此变量 => 使用服务器真实日期（多人真实环境用这个）。
# 本地想快速体验完整 30 天流程，可临时设为某天，例如 2026-08-01
# SIMULATED_TODAY=2026-08-01
